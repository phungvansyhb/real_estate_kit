{
  // ── AI / Agent ──────────────────────────────────────────────────────────────
  "agent": {
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6"
    },
    // Tự động compact thread khi gần hết context window
    "auto_compact_threads": true,

    // Commit message theo Conventional Commits
    "commit_message_instructions": "Dùng Conventional Commits: <type>(<scope>): <mô tả ngắn tiếng Việt>. Types: feat, fix, chore, refactor, docs, style, test. Ví dụ: feat(listing): thêm nút export QR code",

    // Nhiệt độ thấp cho code — chính xác hơn sáng tạo
    "model_parameters": [
      {
        "provider": "anthropic",
        "model": "claude-sonnet-4-6",
        "temperature": 0.1
      }
    ]
  },

  // ── Editor ──────────────────────────────────────────────────────────────────
  "tab_size": 2,
  "hard_tabs": false,
  "format_on_save": "on",
  "formatter": "language_server",

  // ── TypeScript / JavaScript ─────────────────────────────────────────────────
  "languages": {
    "TypeScript": {
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": ["prettier", "--stdin-filepath", "{buffer_path}"]
        }
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.organizeImports": true
      }
    },
    "TSX": {
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": ["prettier", "--stdin-filepath", "{buffer_path}"]
        }
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "JavaScript": {
      "tab_size": 2
    },
    "JSON": {
      "tab_size": 2
    },
    "CSS": {
      "tab_size": 2
    }
  },

  // ── LSP ─────────────────────────────────────────────────────────────────────
  "lsp": {
    "typescript-language-server": {
      "initialization_options": {
        "preferences": {
          "importModuleSpecifierPreference": "non-relative",
          "includeInlayParameterNameHints": "all",
          "includeInlayFunctionParameterTypeHints": true,
          "includeInlayVariableTypeHints": false
        }
      }
    },
    "tailwindcss-language-server": {
      "settings": {
        "tailwindCSS": {
          "experimental": {
            "classRegex": [
              ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
              ["cn\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"]
            ]
          }
        }
      }
    }
  },

  // ── Git ─────────────────────────────────────────────────────────────────────
  "git": {
    "inline_blame_enabled": true,
    "git_gutter": "tracked_files"
  },

  // ── Terminal ─────────────────────────────────────────────────────────────────
  "terminal": {
    "shell": { "program": "zsh" },
    "env": {
      "EDITOR": "zed --wait"
    }
  },

  // ── File exclusions ──────────────────────────────────────────────────────────
  "file_scan_exclusions": [
    "**/.git",
    "**/node_modules",
    "**/.next",
    "**/dist",
    "**/.vercel",
    "**/*.lock"
  ]
}
